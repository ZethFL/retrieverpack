---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('lens', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <div class="room lens-room">
    <article class="post">
      <header class="post-header">
        <a href="/lens/" class="back-link">← Lens</a>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time>{fmtDate(post.data.date)}</time>
          {post.data.author && <span class="post-author">— {post.data.author}</span>}
        </div>
        {post.data.description && <p class="post-description">{post.data.description}</p>}
      </header>
      <div class="post-body">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .lens-room {
    --room-accent: #5ec4a8;
    --room-accent-soft: #7dd4bc;
    --room-bg: #0d1117;
    --room-text: #cdd9e5;
    --room-text-secondary: #768390;
    --room-border: #1e2830;
  }

  .room {
    background: var(--room-bg);
    color: var(--room-text);
    min-height: calc(100vh - 56px - 80px);
    font-family: var(--font-sans);
  }

  .post {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--room-text-secondary);
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--room-accent); }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: var(--room-text);
    margin-bottom: 0.75rem;
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--room-text-secondary);
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.05rem;
    color: var(--room-text-secondary);
    font-style: italic;
    border-left: 3px solid var(--room-accent);
    padding-left: 1rem;
    margin: 1.5rem 0 2.5rem;
    line-height: 1.6;
  }

  .post-body {
    font-size: 1rem;
    line-height: 1.8;
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 2.5rem 0 0.75rem;
    color: var(--room-text);
    letter-spacing: -0.02em;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.5rem;
    color: var(--room-text);
  }

  .post-body :global(p) {
    margin: 0 0 1.25rem;
    color: var(--room-text);
  }

  .post-body :global(strong) {
    color: #e6edf3;
    font-weight: 600;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--room-accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--room-text-secondary);
    font-style: italic;
  }

  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
    color: var(--room-text);
  }

  .post-body :global(a) {
    color: var(--room-accent);
  }
  .post-body :global(a:hover) {
    color: var(--room-accent-soft);
  }

  @media (max-width: 600px) {
    .post { padding: 2rem 1.25rem 3rem; }
  }
</style>
